# ── REQUIRED — agent will not start without these ─────────────────────────────
BACKEND_URL=https://your-backend.onrender.com     # point to YOUR backend URL
AGENT_API_SECRET=your_shared_secret_here          # must match backend AGENT_API_SECRET
USER_ID=                                          # get from MongoDB: Users > _id (your user doc)

# ── PACIFICA SIGNING KEYS ──────────────────────────────────────────────────────
PACIFICA_BASE_URL=https://test-api.pacifica.fi/api/v1
PACIFICA_WS_URL=wss://test-ws.pacifica.fi/ws
PACIFICA_PRIVATE_KEY=your_main_wallet_private_key_base58
PACIFICA_AGENT_PRIVATE_KEY=secret_from_test-app.pacifica.fi/apikey
PACIFICA_AGENT_PUBLIC_KEY=api_key_from_test-app.pacifica.fi/apikey

# ── AI KEYS ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_key
ELFA_API_KEY=your_elfa_key

# ── SAFETY OVERRIDE ────────────────────────────────────────────────────────────
# DRY_RUN stays in env as a hard safety switch — even if backend says dryRun=false,
# you can force simulation mode here by keeping this true
DRY_RUN=true

# ── REMOVED (now come from backend config, not env) ───────────────────────────
# TRADE_SYMBOLS        → set in dashboard Config tab
# LOOP_INTERVAL_SECONDS → set in dashboard Config tab
# MAX_POSITION_USDC    → set in dashboard Config tab
# MIN_CONFIDENCE       → set in dashboard Config tab
# STOP_LOSS_PCT        → set in dashboard Config tab
# TAKE_PROFIT_PCT      → set in dashboard Config tab
